{
  "name": "@openai/codex-plugin-cc",
  "version": "1.5.0",
  "private": true,
  "type": "module",
  "description": "Use Codex from Claude Code to review code or delegate tasks.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "bump-version": "node scripts/bump-version.mjs",
    "check-version": "node scripts/bump-version.mjs --check",
    "prebuild": "mkdir -p plugins/codex/.generated/app-server-types && codex app-server generate-ts --out plugins/codex/.generated/app-server-types",
    "build": "tsgo -p tsconfig.app-server.json",
    "test": "node --test --test-concurrency=6 tests/*.test.mjs",
    "typecheck": "tsgo -p tsconfig.app-server.json",
    "typecheck:tsc": "tsc -p tsconfig.app-server.json"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260705.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.5.2"
}
